# Local developer configuration overrides template.
# Copy this file to 'application-local.yml' and customize as needed.
# Do not check 'application-local.yml' into source control.

spring:
  datasource:
    # URL for local/test Oracle DB instance
    # Example format: jdbc:oracle:thin:@//<host>:<port>/<service_name>
    url: jdbc:oracle:thin:@//drracx9-scan1:1552/TCMSPDB2
    username: EPICBACKENDSMARTVISTA2
    password: EPICBACKENDSMARTVISTA2

  sql:
    init:
      # Set to 'always' to run schema.sql and data.sql automatically on startup
      # in your local/test schema.
      mode: always
      continue-on-error: true

logging:
  level:
    # Set to DEBUG to print executed SQL queries for debugging
    org.springframework.jdbc.core.JdbcTemplate: DEBUG
    org.springframework.jdbc.core.StatementCreatorUtils: TRACE
